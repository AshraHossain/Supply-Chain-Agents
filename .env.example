# --- LLM configuration -------------------------------------------------------
# Provider: openrouter | anthropic | openai | mock
# "mock" runs the whole graph deterministically with NO API key (great for demos/CI).
LLM_PROVIDER=openrouter

# Model name for the chosen provider.
# OpenRouter uses "vendor/model" slugs, e.g.:
#   anthropic/claude-sonnet-4.5 | openai/gpt-4o-mini | google/gemini-2.0-flash-001
LLM_MODEL=anthropic/claude-sonnet-4.5

# API keys (only the one matching LLM_PROVIDER is required)
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- Business policy ---------------------------------------------------------
# Orders above EITHER threshold require human approval (step 5 of the roadmap).
APPROVAL_QTY_THRESHOLD=500
APPROVAL_COST_THRESHOLD=10000
